DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fitnama"
AUTH_SECRET="change-me-in-production-use-32-plus-random-chars"
NODE_ENV="development"

# Cron protection (generate a random secret, set in Vercel env vars too)
CRON_SECRET="change-me-cron-secret"

# Object storage — works with S3 or Cloudflare R2 (S3-compatible)
# R2: endpoint = https://<account_id>.r2.cloudflarestorage.com
STORAGE_ENDPOINT=""
STORAGE_REGION="auto"
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_BUCKET="fitnama"
STORAGE_PUBLIC_BASE_URL="https://your-bucket.s3.amazonaws.com"
